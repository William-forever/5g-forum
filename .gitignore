# ========================================
# Git忽略文件配置 - 5G消息交流论坛
# ========================================
# @description 指定不需要纳入版本控制的文件和目录
# @author Forum Team
# @date 2026-03-10
# ========================================

# ========================================
# 操作系统文件
# ========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory

# ========================================
# 编辑器和IDE
# ========================================
# VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains IDEs (IntelliJ, PhpStorm, WebStorm)
.idea/
*.iws
*.iml
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]

# ========================================
# 环境配置文件
# ========================================
.env
.env.local
.env.*.local

# ========================================
# 依赖和构建
# ========================================
node_modules/
bower_components/

# PHP Composer
/vendor/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ========================================
# 日志文件
# ========================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ========================================
# 数据库文件
# ========================================
*.sql.gz
*.sqlite
*.sqlite3
db/*.sqlite3

# ========================================
# 上传文件
# ========================================
uploads/
files/
temp/
tmp/

# ========================================
# 备份文件
# ========================================
*.bak
*.backup
*.old
*~
backups/

# ========================================
# 缓存
# ========================================
.cache/
tmp/
temp/

# ========================================
# 测试和覆盖率
# ========================================
coverage/
.nyc_output/
*.cover
.hypothesis/

# ========================================
# 构建输出
# ========================================
dist/
build/
out/

# ========================================
# 其他
# ========================================
*.swp
*.swo
*~
.project
.settings/
.settings/

# ========================================
# 敏感信息
# ========================================
# 密钥文件
*.key
*.pem
*.p12
*.pfx

# 证书文件
*.crt
*.cer

# 配置文件中的密码
config.php.local
config.local.php
config.inc.php

# ========================================
# 临时文件
# ========================================
*.tmp
*.temp
temp.*
tmp.*
.vercel
