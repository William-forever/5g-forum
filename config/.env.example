# ========================================
# 环境变量配置文件 - 5G消息交流论坛
# ========================================
# @description 环境变量配置模板
# @note 复制此文件为 .env 并填入实际配置值
# ========================================

# ========================================
# 数据库配置
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=forum_db
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_CHARSET=utf8mb4

# ========================================
# 网站配置
# ========================================
SITE_URL=http://localhost:8000
SITE_NAME=中移互5G消息交流论坛
SITE_DESCRIPTION=专业的5G消息技术交流平台
SITE_KEYWORDS=5G消息,RCS,消息推送,短信升级

# ========================================
# 文件上传配置
# ========================================
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,doc,xls,xlsx
UPLOAD_PATH=./uploads

# ========================================
# 邮件配置
# ========================================
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@example.com
MAIL_PASSWORD=your_email_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME=5G消息交流论坛

# ========================================
# 短信配置
# ========================================
SMS_ACCESS_KEY=your_access_key
SMS_SECRET_KEY=your_secret_key
SMS_SIGN_NAME=5G消息论坛

# ========================================
# Redis配置（可选）
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ========================================
# 安全配置
# ========================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE_TIME=604800
SESSION_LIFETIME=3600

# ========================================
# 第三方登录配置（可选）
# ========================================
# 微信登录
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# QQ登录
QQ_APP_ID=your_qq_app_id
QQ_APP_SECRET=your_qq_app_secret

# ========================================
# 开发/生产环境配置
# ========================================
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=debug

# ========================================
# 其他配置
# ========================================
TIMEZONE=Asia/Shanghai
LANGUAGE=zh-CN
